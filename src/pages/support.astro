---
import AppShell from '@/layouts/AppShell.astro';
import { OWNER } from '@/config/site';
import { Icon } from 'astro-icon/components';
---

<AppShell title="Support | Awesome Dev Platform" description="Get support or support the Awesome Dev Platform. Contact us for help." keywords="support, help, contact, bug report, discussions, community">
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: 'Support',
      description: 'Get support or support the Awesome Dev Platform. Contact us for help.',
      url: 'https://muhammad-fiaz.github.io/awesome/support/',
    })} />
  </Fragment>
  <div class="px-6 py-12">
    <div class="max-w-2xl mx-auto text-center">
      <Icon name="mdi:help-circle" class="text-5xl text-ds-tertiary mb-4 block" />
      <h1 class="text-3xl font-bold text-ds-on-surface mb-3">Support</h1>
      <p class="text-ds-on-surface-variant text-lg mb-8">
        Need help? Have a question? Want to contribute? Here's how to reach us.
      </p>

      <div class="grid gap-4 sm:grid-cols-2 text-left">
        <a
          href={`${OWNER.github}/issues`}
          target="_blank"
          rel="noopener noreferrer"
          class="card-ds p-5 group hover:no-underline"
        >
          <Icon name="mdi:bug" class="text-2xl text-ds-primary mb-2 block" />
          <h2 class="font-semibold text-ds-on-surface group-hover:text-ds-primary transition-colors">Report an Issue</h2>
          <p class="text-sm text-ds-on-surface-variant mt-1">Found a bug? Open a GitHub issue.</p>
        </a>
        <a
          href={`${OWNER.github}/discussions`}
          target="_blank"
          rel="noopener noreferrer"
          class="card-ds p-5 group hover:no-underline"
        >
          <Icon name="mdi:forum" class="text-2xl text-ds-secondary mb-2 block" />
          <h2 class="font-semibold text-ds-on-surface group-hover:text-ds-primary transition-colors">Discussions</h2>
          <p class="text-sm text-ds-on-surface-variant mt-1">Ask questions in GitHub Discussions.</p>
        </a>
        <a
          href={OWNER.twitter}
          target="_blank"
          rel="noopener noreferrer"
          class="card-ds p-5 group hover:no-underline"
        >
          <Icon name="mdi:email-outline" class="text-2xl text-ds-info mb-2 block" />
          <h2 class="font-semibold text-ds-on-surface group-hover:text-ds-primary transition-colors">Twitter/X</h2>
          <p class="text-sm text-ds-on-surface-variant mt-1">Reach out on X (Twitter).</p>
        </a>
        <a
          href={OWNER.support}
          target="_blank"
          rel="noopener noreferrer"
          class="card-ds p-5 group hover:no-underline"
        >
          <span class="text-2xl mb-2 block">☕</span>
          <h2 class="font-semibold text-ds-on-surface group-hover:text-ds-primary transition-colors">Financial Support</h2>
          <p class="text-sm text-ds-on-surface-variant mt-1">Support the project financially.</p>
        </a>
      </div>
    </div>
  </div>
</AppShell>

---
import PostLayout from '@/layouts/PostLayout.astro';
import { PostHero } from '@/components/post/PostHero';
import { GiscusComments } from '@/components/post/GiscusComments';
import { RelatedPosts } from '@/components/post/RelatedPosts';
import { Recommendations } from '@/components/post/Recommendations';
import AuthorCard from '@/components/post/AuthorCard.astro';
import OrganisationCard from '@/components/post/OrganisationCard.astro';
import Prose from '@/components/common/Prose.astro';
import { CodeCopyButtons } from '@/components/common/CodeCopy';
import { render } from 'astro:content';
import { BASE_PATH, SITE_CONFIG, OWNER } from '@/config/site';
import {
  getAllPosts,
  getAuthorsBySlugs,
  getOrganisationsBySlugs,
  getPostReadingTime,
  getRecommendationPosts,
  getRelatedPosts,
} from '@/lib/posts';
import { PostReferences } from '@/components/post/PostReferences';
import { MobileToc } from '@/components/post/MobileToc';
import { buildToc } from '@/lib/toc';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: {
      slug: post.id.replace(/\.(md|mdx)$/, ''),
    },
    props: { post },
  }));
}

const { post } = Astro.props;

if (!post) {
  return Astro.redirect(`${BASE_PATH}/posts/`);
}

const [relatedPosts, recommendationPosts, postAuthors, postOrganisations] = await Promise.all([
  getRelatedPosts(post, 2),
  getRecommendationPosts(post, 2),
  getAuthorsBySlugs(post.data.authors),
  getOrganisationsBySlugs(post.data.organisations ?? []),
]);

const relatedForComponent = relatedPosts.map((p) => ({
  slug: p.id.replace(/\.(md|mdx)$/, ''),
  title: p.data.title,
  description: p.data.description,
  thumbnail: p.data.thumbnail,
  categories: p.data.categories,
  tags: p.data.tags,
  authors: p.data.authors,
  readingTime: getPostReadingTime(p),
  featured: p.data.featured,
  difficulty: p.data.difficulty,
}));

const recommendationsForComponent = recommendationPosts.map((p) => ({
  slug: p.id.replace(/\.(md|mdx)$/, ''),
  title: p.data.title,
  description: p.data.description,
  thumbnail: p.data.thumbnail,
  categories: p.data.categories,
  tags: p.data.tags,
  authors: p.data.authors,
  readingTime: getPostReadingTime(p),
  featured: p.data.featured,
  difficulty: p.data.difficulty,
}));

import fs from 'node:fs';
import path from 'node:path';

const postFilePath = path.join(process.cwd(), 'src/content/posts', post.id);
let datePublished = new Date().toISOString();
let dateModified = new Date().toISOString();
try {
  if (fs.existsSync(postFilePath)) {
    const stats = fs.statSync(postFilePath);
    datePublished = stats.birthtime.toISOString();
    dateModified = stats.mtime.toISOString();
  }
} catch (e) {
  // Fallback
}

const authorInfoList = postAuthors.length > 0 ? postAuthors.map((a) => ({
  slug: a.id.replace(/\.md$/, ''),
  name: a.data.name,
  title: a.data.title,
  avatar: a.data.avatar,
  bio: a.data.bio,
  location: a.data.location,
  website: a.data.website,
  github: a.data.github,
  twitter: a.data.twitter,
  linkedin: a.data.linkedin,
  portfolio: a.data.portfolio,
  sponsor: a.data.sponsor,
  support: a.data.support,
  email: a.data.email,
  phoneNumber: a.data.phoneNumber,
})) : [{
  slug: 'muhammad-fiaz',
  name: OWNER.name,
  title: 'Founder & Site Owner',
  avatar: 'https://avatars.githubusercontent.com/u/75434191?v=4',
  bio: 'Software Engineer & Open Source Enthusiast',
  location: 'India',
  website: OWNER.portfolio,
  github: OWNER.github,
  twitter: OWNER.twitter,
  linkedin: OWNER.linkedin,
  portfolio: OWNER.portfolio,
  sponsor: OWNER.sponsor,
  support: OWNER.support,
  email: 'contact@muhammadfiaz.com',
  phoneNumber: undefined,
}];

const orgInfoList = postOrganisations.length > 0 ? postOrganisations.map((o) => ({
  slug: o.id.replace(/\.md$/, ''),
  name: o.data.name,
  title: o.data.title,
  avatar: o.data.avatar,
  bio: o.data.bio,
  location: o.data.location,
  website: o.data.website,
  github: o.data.github,
  twitter: o.data.twitter,
  linkedin: o.data.linkedin,
  portfolio: o.data.portfolio,
  sponsor: o.data.sponsor,
  support: o.data.support,
  email: o.data.email,
  phoneNumber: o.data.phoneNumber,
})) : [];

const { Content, headings, remarkPluginFrontmatter } = await render(post);
const toc = buildToc(headings);
const readingTime =
  remarkPluginFrontmatter.minutesRead ?? `${getPostReadingTime(post)} min read`;

const postKeywords = post.data.keywords?.join(', ');

const primaryAuthor = authorInfoList[0];

const postJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  author: authorInfoList.map((a) => ({
    '@type': 'Person',
    name: a.name,
    url: a.website || a.portfolio || `${SITE_CONFIG.url}${BASE_PATH}/authors/${a.slug}/`,
    image: a.avatar,
    email: a.email,
    telephone: a.phoneNumber,
    sameAs: [
      a.github,
      a.twitter,
      a.linkedin,
      a.website,
      a.portfolio,
    ].filter(Boolean),
  })),
  publisher: {
    '@type': 'Person',
    name: OWNER.name,
    url: OWNER.portfolio,
    image: primaryAuthor?.avatar || 'https://avatars.githubusercontent.com/u/75434191?v=4',
    sameAs: [
      OWNER.github,
      OWNER.twitter,
      OWNER.linkedin,
      OWNER.portfolio,
    ],
  },
  image: post.data.thumbnail ?? post.data.customOgImage,
  datePublished,
  dateModified,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${SITE_CONFIG.url}${BASE_PATH}/post/${post.id.replace(/\.(md|mdx)$/, '')}/`,
  },
  keywords: post.data.keywords?.join(', '),
  inLanguage: post.data.language || 'en',
};

const postBreadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: `${SITE_CONFIG.url}${BASE_PATH}/`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Posts',
      item: `${SITE_CONFIG.url}${BASE_PATH}/posts/`,
    },
    ...(post.data.categories.length > 0
      ? [
          {
            '@type': 'ListItem',
            position: 3,
            name: post.data.categories[0],
            item: `${SITE_CONFIG.url}${BASE_PATH}/categories/${post.data.categories[0].toLowerCase().replace(/\s+/g, '-')}/`,
          },
        ]
      : []),
    {
      '@type': 'ListItem',
      position: post.data.categories.length > 0 ? 4 : 3,
      name: post.data.title,
      item: `${SITE_CONFIG.url}${BASE_PATH}/post/${post.id.replace(/\.(md|mdx)$/, '')}/`,
    },
  ],
};

const postLinks: Record<string, string | undefined> = {};
if (post.data.links) {
  for (const [k, v] of Object.entries(post.data.links)) {
    if (v && typeof v === 'string' && v.trim()) {
      postLinks[k] = v;
    }
  }
}
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.customOgImage ?? post.data.thumbnail ?? `https://placehold.co/1200x630/0f172a/f8fafc/png?text=${encodeURIComponent(post.data.title)}`}
  headings={headings}
  postLinks={postLinks}
  keywords={postKeywords}
>

  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(postJsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(postBreadcrumbJsonLd)} />
    <meta property="article:author" content={authorInfoList.map(a => a.name).join(', ')} />
    <meta property="article:published_time" content={datePublished} />
    <meta property="article:modified_time" content={dateModified} />
    {post.data.language && <meta property="article:language" content={post.data.language} />}
    {post.data.categories.length > 0 && <meta property="article:section" content={post.data.categories[0]} />}
    {post.data.tags.length > 0 && post.data.tags.map((tag: string) => (
      <meta property="article:tag" content={tag} />
    ))}
  </Fragment>
  <PostHero
    client:load
    title={post.data.title}
    description={post.data.description}
    heroImage={post.data.heroImage}
    thumbnail={post.data.thumbnail}
    categories={post.data.categories}
    tags={post.data.tags}
    authors={post.data.authors}
    readingTime={readingTime}
    license={post.data.license}
    difficulty={post.data.difficulty}
  />

  <div class="py-4 max-w-5xl mx-auto px-4 sm:px-6 md:px-8 xl:px-10">
    <div class="w-full">
      <MobileToc client:load toc={toc} />
      <Prose>
        <Content />
      </Prose>

      <CodeCopyButtons client:load />

      {post.data.references && post.data.references.length > 0 && (
        <PostReferences client:load references={post.data.references} />
      )}

      {post.data.tags && post.data.tags.length > 0 && (
        <div class="mt-10 pt-6 border-t border-ds-outline-variant">
          <h2 class="text-lg font-semibold text-ds-on-surface mb-3">Tags</h2>
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map((tag: string) => (
              <a
                href={`${BASE_PATH}/tags/${tag}/`}
                class="tag-ds"
              >
                #{tag}
              </a>
            ))}
          </div>
        </div>
      )}

      {orgInfoList.length > 0 && (
        <OrganisationCard organisations={orgInfoList} />
      )}

      <AuthorCard authors={authorInfoList} />

      {relatedForComponent.length > 0 && (
        <RelatedPosts client:load posts={relatedForComponent} />
      )}

      {recommendationsForComponent.length > 0 && (
        <Recommendations client:load posts={recommendationsForComponent} />
      )}

      <GiscusComments client:load term={post.id.replace(/\.(md|mdx)$/, '')} />
    </div>
  </div>
</PostLayout>

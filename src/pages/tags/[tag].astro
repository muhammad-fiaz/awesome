---
import AppShell from '@/layouts/AppShell.astro';
import { PostsFeed } from '@/components/post/PostsFeed';
import { ListingSidebar } from '@/components/layout/ListingSidebar';
import { HugeiconsIcon } from '@hugeicons/react';
import { ArrowLeft01Icon, TagsIcon } from '@hugeicons/core-free-icons';
import {
  getAllTags,
  getPostReadingTime,
  getPostsByTag,
  getAllCategories,
  getAllPosts,
} from '@/lib/posts';
import { BASE_PATH, SITE_CONFIG } from '@/config/site';

export async function getStaticPaths() {
  const tags = await getAllTags();
  return tags.map((tag) => ({
    params: { tag: tag.id.replace(/\.md$/, '') },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const slug = tag.id.replace(/\.md$/, '');
const posts = await getPostsByTag(slug);
const allPosts = await getAllPosts();
const tagsList = await getAllTags();
const categories = await getAllCategories();

const postItems = posts.map((p) => ({
  slug: p.id.replace(/\.(md|mdx)$/, ''),
  title: p.data.title,
  description: p.data.description,
  thumbnail: p.data.thumbnail,
  categories: p.data.categories,
  tags: p.data.tags,
  authors: p.data.authors,
  readingTime: getPostReadingTime(p),
  featured: p.data.featured,
  difficulty: p.data.difficulty,
  sources: p.data.sources,
}));

const tagItems = tagsList
  .map((t) => ({
    slug: t.id.replace(/\.md$/, ''),
    title: t.data.title,
    count: allPosts.filter((post) => post.data.tags.includes(t.id.replace(/\.md$/, ''))).length,
  }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 10);

const categoryItems = categories
  .map((c) => ({
    slug: c.id.replace(/\.md$/, ''),
    title: c.data.title,
    count: allPosts.filter((post) => post.data.categories.includes(c.id.replace(/\.md$/, ''))).length,
  }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 5);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `#${tag.data.title}`,
  description: tag.data.description ?? `Resources tagged with ${tag.data.title}`,
  url: `${Astro.url.origin}${BASE_PATH}/tags/${slug}/`,
  isPartOf: {
    '@type': 'WebSite',
    name: SITE_CONFIG.name,
    url: `${Astro.url.origin}${BASE_PATH}/`,
  },
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${Astro.url.origin}${BASE_PATH}/` },
      { '@type': 'ListItem', position: 2, name: 'Tags', item: `${Astro.url.origin}${BASE_PATH}/tags/` },
      { '@type': 'ListItem', position: 3, name: tag.data.title },
    ],
  },
};
---

<AppShell
  title={`${tag.data.title} Tag`}
  description={tag.data.description ?? `Resources tagged with ${tag.data.title}`}
>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="px-4 md:px-6 py-8">
    <div class="max-w-320 mx-auto">
      <!-- Breadcrumbs -->
      <div class="flex items-center gap-2 mb-6 text-sm">
        <a href={`${BASE_PATH}/`} class="text-ds-text-muted hover:text-ds-on-surface transition-colors">Home</a>
        <span class="text-ds-text-muted">/</span>
        <a href={`${BASE_PATH}/tags/`} class="text-ds-text-muted hover:text-ds-on-surface transition-colors">Tags</a>
        <span class="text-ds-text-muted">/</span>
        <span class="text-sm text-ds-on-surface font-medium truncate max-w-[200px]">#{tag.data.title}</span>
      </div>

      <div class="mb-8">
        <h1 class="font-mono text-3xl font-bold text-ds-primary mb-2">
          #{tag.data.title}
        </h1>
        {tag.data.description && (
          <p class="text-ds-on-surface-variant">{tag.data.description}</p>
        )}
      </div>

      {/* Sidebar Layout */}
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        {/* Main column */}
        <div class="lg:col-span-2">
          {postItems.length === 0 ? (
            <div class="text-center py-16 text-ds-text-muted">
              <HugeiconsIcon icon={TagsIcon} className="w-12 h-12 mx-auto mb-3 opacity-50" size={48} />
              <p class="text-base font-semibold text-ds-on-surface mb-1">No posts yet</p>
              <p class="text-sm">No posts with this tag yet. Check back later.</p>
            </div>
          ) : (
            <PostsFeed client:load posts={postItems} showSearch={true} />
          )}
        </div>

        {/* Sidebar widgets */}
        <div class="space-y-6">
          <ListingSidebar type="post" categories={categoryItems} tags={tagItems} client:load />
        </div>
      </div>
    </div>
  </div>
</AppShell>

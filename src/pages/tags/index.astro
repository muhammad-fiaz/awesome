---
import AppShell from '@/layouts/AppShell.astro';
import { TagsFeed } from '@/components/listing/TagsFeed';
import { getAllPosts, getAllTags } from '@/lib/posts';
import { SITE_CONFIG, BASE_PATH } from '@/config/site';

const tags = await getAllTags();
const allPosts = await getAllPosts();

const tagItems = tags.map((t) => ({
  slug: t.id.replace(/\.md$/, ''),
  title: t.data.title,
  count: allPosts.filter((p) => p.data.tags.includes(t.id.replace(/\.md$/, '')))
    .length,
}));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Browse Tags',
  description: 'Browse all tags across developer resources, tutorials, and tools.',
  url: `${Astro.url.origin}${SITE_CONFIG.basePath}/tags/`,
  isPartOf: {
    '@type': 'WebSite',
    name: SITE_CONFIG.name,
    url: `${Astro.url.origin}${SITE_CONFIG.basePath}/`,
  },
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${Astro.url.origin}${SITE_CONFIG.basePath}/` },
      { '@type': 'ListItem', position: 2, name: 'Tags' },
    ],
  },
};
---

<AppShell title="Browse Tags" description="Browse all tags across developer resources, tutorials, and tools." keywords="developer tags, programming topics, technology categories, filter by tag">

  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
  </Fragment>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="px-4 md:px-6 py-8">
    <div class="max-w-320 mx-auto">
      <!-- Breadcrumbs -->
      <div class="flex items-center gap-2 mb-4 text-sm">
        <a href={`${BASE_PATH}/`} class="text-ds-text-muted hover:text-ds-on-surface transition-colors">Home</a>
        <span class="text-ds-text-muted">/</span>
        <span class="text-sm text-ds-on-surface font-medium">Tags</span>
      </div>
      <div class="mb-10">
        <h1 class="text-2xl md:text-4xl font-bold text-ds-on-surface mb-2">Tags</h1>
        <p class="text-ds-on-surface-variant text-base md:text-lg">
          Browse all tags across developer resources.
        </p>
      </div>

      {tagItems.length === 0 ? (
        <div class="card-ds p-16 text-center">
          <p class="text-ds-text-muted text-lg">No content available yet</p>
        </div>
      ) : (
        <TagsFeed client:load tags={tagItems} />
      )}
    </div>
  </div>
</AppShell>

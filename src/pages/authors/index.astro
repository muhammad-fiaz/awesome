---
import AppShell from '@/layouts/AppShell.astro';
import { AuthorsFeed } from '@/components/listing/AuthorsFeed';
import { ListingSidebar } from '@/components/layout/ListingSidebar';
import {
  getAllAuthors,
  getAllCategories,
  getAllTags,
  getAllPosts,
} from '@/lib/posts';
import { SITE_CONFIG, BASE_PATH } from '@/config/site';

const authors = await getAllAuthors();
const allPosts = await getAllPosts();
const tags = await getAllTags();
const categories = await getAllCategories();

const authorItems = authors
  .map((a) => ({
    slug: a.id.replace(/\.md$/, ''),
    name: a.data.name,
    title: a.data.title,
    avatar: a.data.avatar,
    bio: a.data.bio,
    location: a.data.location,
  }));

const tagItems = tags
  .map((t) => ({
    slug: t.id.replace(/\.md$/, ''),
    title: t.data.title,
    count: allPosts.filter((post) => post.data.tags.includes(t.id.replace(/\.md$/, ''))).length,
  }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 10);

const categoryItems = categories
  .map((c) => ({
    slug: c.id.replace(/\.md$/, ''),
    title: c.data.title,
    count: allPosts.filter((post) => post.data.categories.includes(c.id.replace(/\.md$/, ''))).length,
  }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 5);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Authors and Contributors',
  description: 'Meet the contributors and authors of the Awesome Dev Platform.',
  url: `${Astro.url.origin}${SITE_CONFIG.basePath}/authors/`,
  isPartOf: {
    '@type': 'WebSite',
    name: SITE_CONFIG.name,
    url: `${Astro.url.origin}${SITE_CONFIG.basePath}/`,
  },
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${Astro.url.origin}${SITE_CONFIG.basePath}/` },
      { '@type': 'ListItem', position: 2, name: 'Authors' },
    ],
  },
};
---

<AppShell title="Authors and Contributors" description="Meet the contributors and authors of the Awesome Dev Platform." keywords="authors, contributors, developer community, writers, content creators">

  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
  </Fragment>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="px-4 md:px-6 py-8">
    <div class="max-w-320 mx-auto">

      <!-- Breadcrumbs -->
      <div class="flex items-center gap-2 mb-4 text-sm">
        <a href={`${BASE_PATH}/`} class="text-ds-text-muted hover:text-ds-on-surface transition-colors">Home</a>
        <span class="text-ds-text-muted">/</span>
        <span class="text-sm text-ds-on-surface font-medium">Authors</span>
      </div>

      <!-- Page header -->
      <div class="mb-10">
        <h1 class="text-2xl md:text-4xl font-bold text-ds-on-surface mb-2">
          Our Authors
        </h1>
        <p class="text-ds-on-surface-variant text-base md:text-lg">
          Meet the contributors sharing knowledge with the community
        </p>
      </div>

      {/* Sidebar Layout */}
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        {/* Main column */}
        <div class="lg:col-span-2">
          {authorItems.length === 0 ? (
            <div class="card-ds p-16 text-center">
              <p class="text-ds-text-muted text-lg">No content available yet</p>
            </div>
          ) : (
            <AuthorsFeed client:load authors={authorItems} />
          )}
        </div>

        {/* Sidebar widgets */}
        <div class="space-y-6">
          <ListingSidebar type="post" categories={categoryItems} tags={tagItems} client:load />
        </div>
      </div>
    </div>
  </div>
</AppShell>

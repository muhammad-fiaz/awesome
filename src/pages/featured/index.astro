---
import AppShell from '@/layouts/AppShell.astro';
import { PostsFeed } from '@/components/post/PostsFeed';
import { HugeiconsIcon } from '@hugeicons/react';
import { StarIcon, ArrowLeft01Icon, File02Icon, Clock01Icon, TagsIcon } from '@hugeicons/core-free-icons';
import { getAllTags, getFeaturedPosts, getPostReadingTime } from '@/lib/posts';
import { BASE_PATH, SITE_CONFIG } from '@/config/site';

const featuredPosts = await getFeaturedPosts();
const tags = await getAllTags();

const tagItems = tags.map((t) => ({
  slug: t.id.replace(/\.md$/, ''),
  title: t.data.title,
}));

const posts = featuredPosts.map((p) => ({
  slug: p.id.replace(/\.(md|mdx)$/, ''),
  title: p.data.title,
  description: p.data.description,
  thumbnail: p.data.thumbnail,
  categories: p.data.categories,
  tags: p.data.tags,
  authors: p.data.authors,
  readingTime: getPostReadingTime(p),
  featured: p.data.featured,
  difficulty: p.data.difficulty,
}));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Featured Developer Resources',
  description: 'Hand-picked featured resources, the best developer tutorials, tools, and guides curated by our team.',
  url: `${Astro.url.origin}${BASE_PATH}/featured/`,
  isPartOf: {
    '@type': 'WebSite',
    name: SITE_CONFIG.name,
    url: `${Astro.url.origin}${BASE_PATH}/`,
  },
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${Astro.url.origin}${BASE_PATH}/` },
      { '@type': 'ListItem', position: 2, name: 'Featured' },
    ],
  },
};
---

<AppShell
  title="Featured Developer Resources"
  description="Hand-picked featured resources, the best developer tutorials, tools, and guides curated by our team."
  keywords="featured developer resources, best tutorials, curated tools, top guides, recommended programming"
>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
  </Fragment>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="px-4 md:px-6 py-8">
    <div class="max-w-320 mx-auto">

      <!-- Page Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3 mb-3">
          <div class="p-2 rounded-xl bg-ds-primary-container">
            <HugeiconsIcon icon={StarIcon} className="w-5.5 h-5.5 text-ds-on-primary-container" size={22} />
          </div>
          <h1 class="text-3xl md:text-4xl font-bold text-ds-on-surface tracking-tight">
            Featured Posts
          </h1>
        </div>
        <p class="text-ds-on-surface-variant text-lg max-w-2xl">
          Hand-picked resources, the very best tutorials, tools, and guides curated for you.
        </p>
        <div class="flex items-center gap-2 mt-4">
          <a
            href={`${BASE_PATH}/posts/`}
            class="inline-flex items-center gap-1.5 text-sm text-ds-text-muted hover:text-ds-on-surface transition-colors"
          >
            <HugeiconsIcon icon={ArrowLeft01Icon} className="w-4 h-4" size={16} />
            All Posts
          </a>
          <span class="text-ds-outline-variant">·</span>
          <span class="text-sm text-ds-text-muted">
            Hand-picked resources
          </span>
        </div>
      </div>

      <!-- Grid/List Feed -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <div class="lg:col-span-2">
          {posts.length === 0 ? (
            <div class="card-ds p-16 text-center">
              <HugeiconsIcon icon={StarIcon} className="w-14 h-14 mx-auto mb-4 text-ds-text-muted opacity-30" size={56} />
              <p class="text-ds-text-muted text-lg">No featured posts yet.</p>
              <a href={`${BASE_PATH}/posts/`} class="inline-block mt-4 text-sm text-ds-primary hover:underline">
                Browse all posts →
              </a>
            </div>
          ) : (
            <PostsFeed client:load posts={posts} />
          )}
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <div class="card-ds p-5 sticky top-20">
            <h3 class="text-sm font-bold uppercase tracking-widest text-ds-text-muted mb-4">Quick Links</h3>
            <div class="space-y-1">
              <a
                href={`${BASE_PATH}/posts/`}
                class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-ds-on-surface-variant hover:text-ds-on-surface hover:bg-ds-surface-high transition-colors"
              >
                <HugeiconsIcon icon={File02Icon} className="w-4 h-4" size={16} />
                All Posts
              </a>
              <a
                href={`${BASE_PATH}/latest/`}
                class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-ds-on-surface-variant hover:text-ds-on-surface hover:bg-ds-surface-high transition-colors"
              >
                <HugeiconsIcon icon={Clock01Icon} className="w-4 h-4" size={16} />
                Latest Posts
              </a>
              <a
                href={`${BASE_PATH}/categories/`}
                class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-ds-on-surface-variant hover:text-ds-on-surface hover:bg-ds-surface-high transition-colors"
              >
                <HugeiconsIcon icon={TagsIcon} className="w-4 h-4" size={16} />
                Categories
              </a>
            </div>

            {tagItems.length > 0 && (
              <div class="mt-5 pt-5 border-t border-ds-outline-variant">
                <h4 class="text-xs font-bold uppercase tracking-widest text-ds-text-muted mb-3">Popular Tags</h4>
                <div class="flex flex-wrap gap-1.5">
                  {tagItems.slice(0, 10).map(tag => (
                    <a href={`${BASE_PATH}/tags/${tag.slug}/`} class="tag-ds text-[10px]">
                      #{tag.title}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</AppShell>

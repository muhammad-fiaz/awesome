---
import AppShell from '@/layouts/AppShell.astro';
import { PostsFeed } from '@/components/post/PostsFeed';
import { NewsCard } from '@/components/news/NewsCard';
import Prose from '@/components/common/Prose.astro';
import { MagicCard } from '@/components/ui/magic-card';
import { HugeiconsIcon } from '@hugeicons/react';
import {
  ArrowLeft01Icon,
  Location01Icon,
  CheckmarkCircle01Icon,
  File02Icon,
  GithubIcon,
  NewTwitterIcon,
  LinkedinIcon,
  Globe02Icon,
  Calendar01Icon,
  News01Icon,
} from '@hugeicons/core-free-icons';
import { render, getCollection } from 'astro:content';
import { BASE_PATH, SITE_CONFIG } from '@/config/site';
import {
  getAllOrganisations,
  getPostReadingTime,
  getPostsByOrganisation,
  getAuthorsForOrganisation,
  getAllNews,
} from '@/lib/posts';

export async function getStaticPaths() {
  const organisations = await getAllOrganisations();
  return organisations.map((org) => ({
    params: { organisation: org.id.replace(/\.md$/, '') },
    props: { organisation: org },
  }));
}

const { organisation } = Astro.props;
const slug = organisation.id.replace(/\.md$/, '');
const posts = await getPostsByOrganisation(slug);
const { Content } = await render(organisation);
const linkedAuthors = await getAuthorsForOrganisation(slug);

const allNews = await getAllNews();
const orgNews = allNews
  .filter((n) => n.data.organisations?.includes(slug))
  .sort((a, b) => b.data.datePublished.valueOf() - a.data.datePublished.valueOf());

const postItems = posts.map((p) => ({
  slug: p.id.replace(/\.(md|mdx)$/, ''),
  title: p.data.title,
  description: p.data.description,
  thumbnail: p.data.thumbnail,
  categories: p.data.categories,
  tags: p.data.tags,
  authors: p.data.authors,
  readingTime: getPostReadingTime(p),
  featured: p.data.featured,
  difficulty: p.data.difficulty,
}));

interface Social {
  key: string;
  icon: any;
  href: string | undefined;
  label: string;
}

const socials: Social[] = [
  {
    key: 'github',
    icon: GithubIcon,
    href: organisation.data.github,
    label: 'GitHub',
  },
  {
    key: 'twitter',
    icon: NewTwitterIcon,
    href: organisation.data.twitter,
    label: 'Twitter / X',
  },
  {
    key: 'linkedin',
    icon: LinkedinIcon,
    href: organisation.data.linkedin,
    label: 'LinkedIn',
  },
  {
    key: 'website',
    icon: Globe02Icon,
    href: organisation.data.website,
    label: 'Website',
  },
].filter(
  (s): s is Social & { href: string } =>
    typeof s.href === 'string' && s.href.trim().length > 0,
);

const organisationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: organisation.data.name,
  description: organisation.data.bio,
  logo: organisation.data.avatar,
  image: organisation.data.avatar,
  url: organisation.data.website || `${SITE_CONFIG.url}${BASE_PATH}/organisations/${slug}/`,
  email: organisation.data.email,
  telephone: organisation.data.phoneNumber,
  address: organisation.data.location ? {
    '@type': 'PostalAddress',
    addressLocality: organisation.data.location,
  } : undefined,
  sameAs: [
    organisation.data.github,
    organisation.data.twitter,
    organisation.data.linkedin,
    organisation.data.website,
    organisation.data.portfolio,
  ].filter(Boolean),
  member: linkedAuthors.map(author => ({
    '@type': 'Person',
    name: author.data.name,
    url: `${SITE_CONFIG.url}${BASE_PATH}/authors/${author.id.replace(/\.md$/, '')}/`,
    image: author.data.avatar,
  })),
};
---

<AppShell
  title={organisation.data.name}
  description={organisation.data.bio ?? `Resources by ${organisation.data.name}`}
  ogImage={organisation.data.avatar}
  keywords={`${organisation.data.name}, ${organisation.data.title ?? 'organisation'}, developer, tools, open source`}
>

  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organisationJsonLd)} />
  </Fragment>
  <div class="px-4 md:px-6 pb-16">
      <div class="max-w-320 mx-auto">

      <!-- Breadcrumbs -->
      <div class="flex items-center gap-2 mb-6 pt-4 text-sm">
        <a href={`${BASE_PATH}/`} class="text-ds-text-muted hover:text-ds-on-surface transition-colors">Home</a>
        <span class="text-ds-text-muted">/</span>
        <a href={`${BASE_PATH}/organisations/`} class="text-ds-text-muted hover:text-ds-on-surface transition-colors">Organisations</a>
        <span class="text-ds-text-muted">/</span>
        <span class="text-sm text-ds-on-surface font-medium truncate max-w-[200px]">{organisation.data.name}</span>
      </div>

      <!-- Organisation Hero Card -->
      <MagicCard
        className="rounded-xl mb-10"
        gradientSize={200}
        gradientColor="var(--ds-magic-glow)"
        gradientFrom="var(--ds-magic-glow-from)"
        gradientTo="var(--ds-magic-glow-to)"
        client:load
      >
        <div class="p-6 md:p-8 flex flex-col sm:flex-row items-start gap-6">

          <!-- Logo -->
          <div class="shrink-0 relative overflow-hidden w-24 h-24 md:w-28 md:h-28 rounded-xl ring-4 ring-ds-outline-variant ring-offset-2 ring-offset-ds-surface-card bg-ds-surface-high flex items-center justify-center">
            {organisation.data.avatar ? (
              <img
                src={organisation.data.avatar}
                alt={organisation.data.name}
                class="max-w-full max-h-full object-contain p-1"
                crossorigin="anonymous"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
              />
            ) : null}
            <div class="w-full h-full bg-ds-primary-container text-ds-on-primary-container flex items-center justify-center text-3xl font-bold" style={organisation.data.avatar ? "display: none;" : "display: flex;"}>
              {organisation.data.name.split(' ').map((n: string) => n[0]).join('').slice(0, 2).toUpperCase()}
            </div>
          </div>

          <!-- Info -->
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div>
                <h1 class="text-2xl md:text-3xl font-bold text-ds-on-surface leading-tight">
                  {organisation.data.name}
                </h1>
                {organisation.data.title && (
                  <p class="text-ds-secondary font-medium mt-0.5 text-base">
                    {organisation.data.title}
                  </p>
                )}
                {organisation.data.location && (
                  <p class="text-sm text-ds-text-muted mt-1 flex items-center gap-1">
                    <HugeiconsIcon icon={Location01Icon} className="w-3.5 h-3.5" size={14} />
                    {organisation.data.location}
                  </p>
                )}
              </div>
            </div>

            {organisation.data.bio && (
              <p class="text-sm md:text-base text-ds-on-surface-variant mt-4 max-w-2xl leading-relaxed">
                {organisation.data.bio}
              </p>
            )}

            <!-- Socials -->
            {socials.length > 0 && (
              <div class="flex flex-wrap gap-2 mt-5">
                {socials.map((social) => (
                  <a
                    href={social.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    title={social.label}
                    class="inline-flex items-center gap-2 px-3.5 py-2 rounded-lg text-sm border border-ds-outline-variant text-ds-on-surface-variant hover:border-ds-primary hover:text-ds-on-surface hover:bg-ds-surface-high transition-all duration-150"
                  >
                    <HugeiconsIcon icon={social.icon} className="w-4 h-4" size={16} aria-hidden="true" />
                    <span class="hidden sm:inline">{social.label}</span>
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      </MagicCard>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Main content -->
        <div class="lg:col-span-2 space-y-6">
          {/* Organisation description content if any */}
          {organisation.body && organisation.body.trim() && (
            <div class="card-ds p-6">
              <h2 class="text-lg font-semibold text-ds-on-surface mb-4 flex items-center gap-2">
                <HugeiconsIcon icon={CheckmarkCircle01Icon} className="w-4.5 h-4.5 text-ds-primary" size={18} />
                About {organisation.data.name}
              </h2>
              <Prose>
                <Content />
              </Prose>
            </div>
          )}

          <div>
            <h2 class="text-xl font-semibold text-ds-on-surface mb-5 flex items-center gap-2">
              <HugeiconsIcon icon={File02Icon} className="w-5 h-5 text-ds-secondary" size={20} />
              Resources from {organisation.data.name}
            </h2>

            {postItems.length === 0 ? (
              <div class="card-ds p-10 text-center text-ds-text-muted">
                <HugeiconsIcon icon={File02Icon} className="w-12 h-12 mx-auto mb-3 opacity-30" size={48} />
                <p>No posts yet associated with this organisation.</p>
              </div>
            ) : (
              <PostsFeed client:load posts={postItems} />
            )}
          </div>

          {orgNews.length > 0 && (
            <div class="mt-10">
              <h2 class="text-xl font-semibold text-ds-on-surface mb-5 flex items-center gap-2">
                <HugeiconsIcon icon={News01Icon} className="w-5 h-5 text-ds-primary" size={20} />
                News from {organisation.data.name}
              </h2>
              <div class="space-y-4">
                {orgNews.map((newsItem) => {
                  const newsSlug = newsItem.id.replace(/\.md$/, '');
                  const newsItemData = {
                    slug: newsSlug,
                    title: newsItem.data.title,
                    description: newsItem.data.description,
                    pubDate: newsItem.data.datePublished.toISOString(),
                    authors: newsItem.data.authors,
                    category: newsItem.data.category,
                    tags: newsItem.data.tags,
                    thumbnail: newsItem.data.thumbnail,
                    sources: newsItem.data.sources,
                  };
                  return (
                    <NewsCard news={newsItemData} view="list" client:load />
                  );
                })}
              </div>
            </div>
          )}
        </div>

        <!-- Right sidebar -->
        <div class="space-y-6">
          <!-- Associated Authors -->
          {linkedAuthors.length > 0 && (
            <div class="card-ds p-5">
              <h3 class="text-sm font-bold uppercase tracking-widest text-ds-text-muted mb-4">Associated Authors</h3>
              <div class="space-y-3">
                {linkedAuthors.map((author) => {
                  const authorSlug = author.id.replace(/\.md$/, '');
                  return (
                    <a
                      href={`${BASE_PATH}/authors/${authorSlug}/`}
                      class="flex items-center gap-3 p-2 rounded-lg border border-ds-outline-variant hover:border-ds-primary hover:bg-ds-surface-high/30 group"
                    >
                      <div class="w-8 h-8 rounded-full overflow-hidden shrink-0 ring-1 ring-ds-outline-variant group-hover:ring-ds-primary flex items-center justify-center">
                        {author.data.avatar ? (
                          <img src={author.data.avatar} alt={author.data.name} class="w-full h-full object-cover" />
                        ) : (
                          <span class="text-xs font-bold text-ds-primary">{author.data.name[0]}</span>
                        )}
                      </div>
                      <div class="min-w-0">
                        <span class="block text-sm font-semibold text-ds-on-surface group-hover:text-ds-primary truncate">{author.data.name}</span>
                        {author.data.title && <span class="block text-[10px] text-ds-text-muted truncate">{author.data.title}</span>}
                      </div>
                    </a>
                  );
                })}
              </div>
            </div>
          )}

          <!-- Categories covered -->
          {[...new Set(postItems.flatMap(p => p.categories))].length > 0 && (
            <div class="card-ds p-5">
              <h3 class="text-sm font-bold uppercase tracking-widest text-ds-text-muted mb-4">Categories</h3>
              <div class="flex flex-wrap gap-2">
                {[...new Set(postItems.flatMap(p => p.categories))].map(cat => (
                  <a
                    href={`${BASE_PATH}/categories/${cat}/`}
                    class="tag-ds"
                  >
                    {cat}
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Tags covered -->
          {[...new Set(postItems.flatMap(p => p.tags))].length > 0 && (
            <div class="card-ds p-5">
              <h3 class="text-sm font-bold uppercase tracking-widest text-ds-text-muted mb-4">Tags</h3>
              <div class="flex flex-wrap gap-2">
                {[...new Set(postItems.flatMap(p => p.tags))].map(tag => (
                  <a
                    href={`${BASE_PATH}/tags/${tag}/`}
                    class="tag-ds"
                  >
                    #{tag}
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</AppShell>

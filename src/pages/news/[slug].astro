---
import PostLayout from '@/layouts/PostLayout.astro';
import Prose from '@/components/common/Prose.astro';
import { CodeCopyButtons } from '@/components/common/CodeCopy';
import { GiscusComments } from '@/components/post/GiscusComments';
import { HugeiconsIcon } from '@hugeicons/react';
import { Clock01Icon, Calendar01Icon, UserIcon } from '@hugeicons/core-free-icons';
import { render, getCollection } from 'astro:content';
import { BASE_PATH, SITE_CONFIG, OWNER } from '@/config/site';
import { getAuthorsBySlugs, getOrganisationsBySlugs } from '@/lib/posts';
import { calculateReadingTime } from '@/lib/readingTime';
import { resolveImageUrl } from '@/lib/utils';

export async function getStaticPaths() {
  const newsEntries = await getCollection('news');
  return newsEntries.map((entry) => ({
    params: {
      slug: entry.id.replace(/\.md$/, ''),
    },
    props: { news: entry },
  }));
}

const { news } = Astro.props;

if (!news) {
  return Astro.redirect(`${BASE_PATH}/news/`);
}

const { Content, headings } = await render(news);

// Fetch authors details
const newsAuthorsList = news.data.authors && news.data.authors.length > 0
  ? news.data.authors
  : [];
const authorList = await getAuthorsBySlugs(newsAuthorsList);

// Fetch organisations details
const newsOrgsList = news.data.organisations && news.data.organisations.length > 0
  ? news.data.organisations
  : [];
const orgList = newsOrgsList.length > 0
  ? await getOrganisationsBySlugs(newsOrgsList)
  : [];

const readingTime = Math.ceil(calculateReadingTime(news.body ?? ''));
const formattedDate = new Date(news.data.pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// JSON-LD NewsArticle Schema
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: news.data.title,
  description: news.data.description,
  image: [
    news.data.thumbnail ? `${Astro.url.origin}${resolveImageUrl(news.data.thumbnail)}` : null,
    news.data.heroImage ? `${Astro.url.origin}${resolveImageUrl(news.data.heroImage)}` : null,
  ].filter(Boolean),
  datePublished: news.data.pubDate.toISOString(),
  dateModified: news.data.pubDate.toISOString(),
  author: authorList.map((a) => ({
    '@type': 'Person',
    name: a.data.name,
    url: `${Astro.url.origin}${BASE_PATH}/authors/${a.id.replace(/\.md$/, '')}/`,
  })),
  publisher: {
    '@type': 'Organization',
    name: SITE_CONFIG.name,
    logo: {
      '@type': 'ImageObject',
      url: `${Astro.url.origin}${BASE_PATH}/logo.png`,
    },
  },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: `${SITE_CONFIG.url}${BASE_PATH}/`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'News',
      item: `${SITE_CONFIG.url}${BASE_PATH}/news/`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: news.data.title,
      item: `${SITE_CONFIG.url}${BASE_PATH}/news/${news.id.replace(/\.md$/, '')}/`,
    },
  ],
};

const heroImage = news.data.heroImage || news.data.thumbnail;
---

<PostLayout
  title={news.data.title}
  description={news.data.description}
  headings={headings}
  keywords={news.data.keywords.join(', ')}
  ogImage={heroImage}
>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={news.data.pubDate.toISOString()} />
    <meta property="article:author" content={authorList.map((a) => a.data.name).join(', ')} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>

  <!-- Hero Header -->
  <div class="relative">
    {heroImage && (
      <div class="relative h-48 md:h-80 overflow-hidden rounded-2xl mb-6">
        <img
          src={resolveImageUrl(heroImage)}
          alt={news.data.title}
          class="w-full h-full object-cover opacity-85 dark:opacity-75"
        />
        <div
          class="absolute inset-0"
          style="background: linear-gradient(to bottom, transparent 30%, var(--background) 100%)"
        />
      </div>
    )}

    <div class="px-4 sm:px-6 md:px-8 xl:px-10 pb-6">
      <div class="flex items-center gap-2 mb-4 text-sm">
        <a href={`${BASE_PATH}/`} class="text-ds-text-muted hover:text-ds-on-surface transition-colors">Home</a>
        <span class="text-ds-outline-variant">/</span>
        <a href={`${BASE_PATH}/news/`} class="text-ds-text-muted hover:text-ds-on-surface transition-colors">News</a>
        <span class="text-ds-outline-variant">/</span>
        <span class="text-ds-on-surface font-medium truncate max-w-40 sm:max-w-xs">{news.data.title}</span>
      </div>

      <h1 class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-ds-on-surface tracking-tight mb-3 leading-tight">
        {news.data.title}
      </h1>

      <div class="flex flex-wrap items-center gap-4 text-sm mt-5">
        {/* Authors list */}
        {authorList.map((authorObj) => {
          const authorSlug = authorObj.id.replace(/\.md$/, '');
          const authorName = authorObj.data.name;
          const authorAvatar = authorObj.data.avatar;
          return (
            <div class="flex items-center gap-2">
              <a
                href={`${BASE_PATH}/authors/${authorSlug}/`}
                class="flex items-center gap-2 text-ds-on-surface-variant hover:text-ds-on-surface transition-colors"
              >
                {authorAvatar ? (
                  <img
                    src={resolveImageUrl(authorAvatar)}
                    alt={authorName}
                    class="w-7 h-7 rounded-full object-cover ring-1 ring-ds-outline-variant"
                    loading="lazy"
                    crossorigin="anonymous"
                  />
                ) : (
                  <div class="w-7 h-7 rounded-full bg-ds-primary-container text-ds-on-primary-container flex items-center justify-center text-[10px] font-bold">
                    {authorName.slice(0, 2).toUpperCase()}
                  </div>
                )}
                <span class="font-medium">{authorName}</span>
              </a>
            </div>
          );
        })}

        {orgList.length > 0 && (
          <>
            <span class="text-ds-outline">·</span>
            <span class="text-ds-text-muted">linked to</span>
            {orgList.map((orgObj, idx) => {
              const orgSlug = orgObj.id.replace(/\.md$/, '');
              return (
                <a
                  href={`${BASE_PATH}/organisations/${orgSlug}/`}
                  class="text-ds-primary hover:underline font-semibold"
                >
                  {orgObj.data.name}
                  {idx < orgList.length - 1 && <span class="text-ds-outline-variant">,</span>}
                </a>
              );
            })}
          </>
        )}

        <span class="text-ds-outline">·</span>

        {/* Date */}
        <span class="flex items-center gap-1.5 text-ds-text-muted">
          <HugeiconsIcon icon={Calendar01Icon} className="w-4 h-4 shrink-0" size={14} strokeWidth={1.5} />
          <span>{formattedDate}</span>
        </span>

        <span class="text-ds-outline">·</span>

        {/* Reading time */}
        <span class="flex items-center gap-1.5 text-ds-text-muted">
          <HugeiconsIcon icon={Clock01Icon} className="w-4 h-4 shrink-0" size={14} strokeWidth={1.5} />
          <span>{readingTime} min read</span>
        </span>
      </div>
    </div>
  </div>

  {/* Content Body */}
  <div class="py-4">
    <div class="max-w-4xl mx-auto px-4 md:px-6">
      <Prose>
        <Content />
      </Prose>

      {/* Code Copy Utility */}
      <CodeCopyButtons client:load />

      {/* Discussion comments */}
      <div class="mt-12 pt-8 border-t border-ds-outline-variant">
        <h3 class="text-lg font-bold text-ds-on-surface mb-6">Discussion</h3>
        <GiscusComments client:only="react" />
      </div>
    </div>
  </div>
</PostLayout>

---
import AppShell from '@/layouts/AppShell.astro';
import { PostsFeed } from '@/components/post/PostsFeed';
import { ListingSidebar } from '@/components/layout/ListingSidebar';
import { HugeiconsIcon } from '@hugeicons/react';
import { ArrowLeft01Icon, FolderOpenIcon } from '@hugeicons/core-free-icons';
import {
  getAllCategories,
  getPostReadingTime,
  getPostsByCategory,
  getAllTags,
  getAllPosts,
} from '@/lib/posts';
import { BASE_PATH, SITE_CONFIG } from '@/config/site';

export async function getStaticPaths() {
  const categories = await getAllCategories();
  return categories.map((cat) => ({
    params: { category: cat.id.replace(/\.md$/, '') },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const slug = category.id.replace(/\.md$/, '');
const posts = await getPostsByCategory(slug);
const allPosts = await getAllPosts();
const tags = await getAllTags();
const categoriesList = await getAllCategories();

const postItems = posts.map((p) => ({
  slug: p.id.replace(/\.(md|mdx)$/, ''),
  title: p.data.title,
  description: p.data.description,
  thumbnail: p.data.thumbnail,
  categories: p.data.categories,
  tags: p.data.tags,
  authors: p.data.authors,
  readingTime: getPostReadingTime(p),
  featured: p.data.featured,
  difficulty: p.data.difficulty,
  projectName: p.data.projectName,
}));

const tagItems = tags
  .map((t) => ({
    slug: t.id.replace(/\.md$/, ''),
    title: t.data.title,
    count: allPosts.filter((post) => post.data.tags.includes(t.id.replace(/\.md$/, ''))).length,
  }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 10);

const categoryItems = categoriesList
  .map((c) => ({
    slug: c.id.replace(/\.md$/, ''),
    title: c.data.title,
    count: allPosts.filter((post) => post.data.categories.includes(c.id.replace(/\.md$/, ''))).length,
  }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 5);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: category.data.title,
  description: category.data.description ?? `Resources in ${category.data.title}`,
  url: `${Astro.url.origin}${BASE_PATH}/categories/${slug}/`,
  isPartOf: {
    '@type': 'WebSite',
    name: SITE_CONFIG.name,
    url: `${Astro.url.origin}${BASE_PATH}/`,
  },
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${Astro.url.origin}${BASE_PATH}/` },
      { '@type': 'ListItem', position: 2, name: 'Categories', item: `${Astro.url.origin}${BASE_PATH}/categories/` },
      { '@type': 'ListItem', position: 3, name: category.data.title },
    ],
  },
};
---

<AppShell
  title={category.data.title}
  description={category.data.description ?? `Resources in ${category.data.title}`}
  ogImage={category.data.customOgImage}
>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="px-6 py-8">
    <div class="max-w-320 mx-auto">
      <!-- Hero -->
      {category.data.heroImage && (
        <div class="relative h-40 rounded-xl overflow-hidden mb-6">
          <img src={category.data.heroImage} alt={category.data.title} class="w-full h-full object-cover opacity-60" />
          <div class="absolute inset-0 bg-linear-to-t from-background to-transparent" />
        </div>
      )}

      <!-- Breadcrumbs -->
      <div class="flex items-center gap-2 mb-4 text-sm">
        <a href={`${BASE_PATH}/`} class="text-ds-text-muted hover:text-ds-on-surface transition-colors">Home</a>
        <span class="text-ds-outline-variant">/</span>
        <a href={`${BASE_PATH}/categories/`} class="text-ds-text-muted hover:text-ds-on-surface transition-colors">Categories</a>
        <span class="text-ds-outline-variant">/</span>
        <span class="text-sm text-ds-on-surface font-medium truncate max-w-[200px]">{category.data.title}</span>
      </div>

      <div class="mb-8">
        <h1 class="text-3xl font-bold text-ds-on-surface mb-2">{category.data.title}</h1>
        {category.data.description && (
          <p class="text-ds-on-surface-variant">{category.data.description}</p>
        )}
      </div>

      {/* Sidebar Layout */}
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        {/* Main column */}
        <div class="lg:col-span-2">
          {postItems.length === 0 ? (
            <div class="text-center py-16 text-ds-text-muted">
              <HugeiconsIcon icon={FolderOpenIcon} className="w-12 h-12 mx-auto mb-3 opacity-50" size={48} />
              <p class="text-base font-semibold text-ds-on-surface mb-1">No posts yet</p>
              <p class="text-sm">No posts in this category yet. Check back later.</p>
            </div>
          ) : (
            <PostsFeed client:load posts={postItems} showSearch={true} />
          )}
        </div>

        {/* Sidebar widgets */}
        <div class="space-y-6">
          <ListingSidebar type="post" categories={categoryItems} tags={tagItems} client:load />
        </div>
      </div>
    </div>
  </div>
</AppShell>

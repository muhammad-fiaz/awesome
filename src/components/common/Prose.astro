---
<div
  class="prose prose-awesome dark:prose-invert max-w-none prose-animate
    prose-headings:font-bold prose-headings:tracking-tight
    prose-h1:text-3xl prose-h2:text-2xl prose-h3:text-xl prose-h4:text-lg
    prose-a:text-ds-primary prose-a:no-underline hover:prose-a:underline
    prose-code:text-ds-secondary prose-code:font-semibold
    prose-code:before:content-none prose-code:after:content-none
    prose-pre:bg-ds-surface-lowest prose-pre:border prose-pre:border-ds-outline-variant prose-pre:group
    prose-blockquote:border-l-ds-primary prose-blockquote:bg-ds-surface-high prose-blockquote:rounded-r-lg
    prose-img:rounded-xl prose-img:shadow-md
    prose-table:border prose-table:border-ds-outline-variant
    prose-th:bg-ds-surface-high prose-th:text-ds-on-surface
    prose-td:text-ds-on-surface-variant
    prose-hr:border-ds-outline-variant
    prose-strong:text-ds-on-surface
    prose-li:text-ds-on-surface
    prose-p:text-ds-on-surface
    prose-lead:text-ds-on-surface-variant"
>
  <slot />
</div>

<style is:global>
  .prose table {
    border-collapse: separate;
    border-spacing: 0;
    width: 100%;
    overflow: hidden;
    border-radius: var(--radius-md);
    border: 1px solid var(--ds-outline-variant);
    margin: 1.5rem 0;
    display: table;
  }

  .prose thead th {
    background: var(--ds-surface-high);
    color: var(--ds-on-surface);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--ds-outline-variant);
    white-space: nowrap;
  }

  .prose thead tr th:first-child {
    border-top-left-radius: calc(var(--radius-md) - 1px);
  }

  .prose thead tr th:last-child {
    border-top-right-radius: calc(var(--radius-md) - 1px);
  }

  .prose tbody td {
    color: var(--ds-on-surface-variant);
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--ds-outline-variant);
    vertical-align: top;
  }

  .prose tbody tr:last-child td {
    border-bottom: none;
  }

  .prose tbody tr:last-child td:first-child {
    border-bottom-left-radius: calc(var(--radius-md) - 1px);
  }

  .prose tbody tr:last-child td:last-child {
    border-bottom-right-radius: calc(var(--radius-md) - 1px);
  }

  .prose tbody tr {
    transition: background-color 0.15s ease;
  }

  .prose tbody tr:hover {
    background: var(--ds-surface-high);
  }

  .prose td,
  .prose th {
    word-break: break-word;
  }

  .prose th {
    white-space: nowrap;
  }

  .prose table a {
    color: var(--ds-primary);
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color 0.2s;
  }

  .prose table a:hover {
    text-decoration-color: var(--ds-primary);
  }

  .prose pre {
    position: relative;
    overflow: auto;
    border-radius: var(--radius-md);
  }

  .prose pre:hover {
    border-color: var(--ds-primary);
  }

  .prose pre code {
    user-select: text;
    -webkit-user-select: text;
  }
</style>

---
import { HugeiconsIcon } from '@hugeicons/react';
import {
  Globe02Icon,
  GithubIcon,
  NewTwitterIcon,
  LinkedinIcon,
  Location01Icon,
  FavouriteIcon,
  HandHeartIcon,
} from '@hugeicons/core-free-icons';
import { BASE_PATH } from '@/config/site';
import { getInitials } from '@/lib/utils';
import { MagicCard } from '@/components/ui/magic-card';

export interface OrganisationInfo {
  slug: string;
  name: string;
  title?: string;
  avatar?: string;
  bio?: string;
  location?: string;
  website?: string;
  github?: string;
  twitter?: string;
  linkedin?: string;
  portfolio?: string;
  sponsor?: string;
  support?: string;
}

interface Props {
  organisations: OrganisationInfo[];
}

const { organisations } = Astro.props;

function getSocialLinks(org: OrganisationInfo) {
  const links: { key: string; icon: any; href: string; label: string; highlight?: boolean }[] = [];
  if (org.website) links.push({ key: 'website', icon: Globe02Icon, href: org.website, label: 'Website' });
  if (org.github) links.push({ key: 'github', icon: GithubIcon, href: org.github, label: 'GitHub' });
  if (org.twitter) links.push({ key: 'twitter', icon: NewTwitterIcon, href: org.twitter, label: 'Twitter / X' });
  if (org.linkedin) links.push({ key: 'linkedin', icon: LinkedinIcon, href: org.linkedin, label: 'LinkedIn' });
  if (org.sponsor) links.push({ key: 'sponsor', icon: FavouriteIcon, href: org.sponsor, label: 'Sponsor', highlight: true });
  if (org.support) links.push({ key: 'support', icon: HandHeartIcon, href: org.support, label: 'Support', highlight: true });
  return links;
}
---

{organisations.length > 0 && (
  <div class="mt-10 pt-6 border-t border-ds-outline-variant">
    <h2 class="text-lg font-semibold text-ds-on-surface mb-4">
      {organisations.length === 1 ? 'Associated Organisation' : 'Associated Organisations'}
    </h2>
    <div class="space-y-4">
      {organisations.map((org) => {
        const socialLinks = getSocialLinks(org);
        const sponsorLinks = socialLinks.filter(l => l.highlight);
        const regularLinks = socialLinks.filter(l => !l.highlight);
        return (
          <MagicCard client:load className="rounded-xl w-full" gradientSize={180} gradientColor="var(--ds-magic-glow)">
            <div class="p-5 flex flex-col sm:flex-row items-start gap-4 w-full h-full bg-transparent border-0">
              <a href={`${BASE_PATH}/organisations/${org.slug}/`} class="shrink-0 relative overflow-hidden rounded-xl w-16 h-16 ring-2 ring-ds-outline-variant hover:ring-ds-primary transition-all bg-ds-surface-high flex items-center justify-center">
                {org.avatar ? (
                  <img
                    src={org.avatar}
                    alt={org.name}
                    class="max-w-full max-h-full object-contain"
                    loading="lazy"
                    crossorigin="anonymous"
                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                  />
                ) : null}
                <div class="w-full h-full bg-ds-primary-container text-ds-on-primary-container flex items-center justify-center text-lg font-bold" style={org.avatar ? "display: none;" : "display: flex;"}>
                  {getInitials(org.name)}
                </div>
              </a>

              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <a href={`${BASE_PATH}/organisations/${org.slug}/`} class="group">
                    <h3 class="font-bold text-ds-on-surface group-hover:text-ds-primary transition-colors text-base">
                      {org.name}
                    </h3>
                  </a>
                  {org.location && (
                    <span class="text-xs text-ds-text-muted flex items-center gap-0.5">
                      <HugeiconsIcon icon={Location01Icon} className="w-3 h-3" size={12} />
                      {org.location}
                    </span>
                  )}
                </div>
                {org.title && (
                  <p class="text-xs text-ds-on-surface-variant mt-0.5">{org.title}</p>
                )}
                {org.bio && (
                  <p class="text-sm text-ds-text-muted mt-2 leading-relaxed line-clamp-3">{org.bio}</p>
                )}

                <div class="flex flex-wrap items-center gap-2 mt-3">
                  {regularLinks.map((link) => (
                    <a
                      href={link.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      title={link.label}
                      class="inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-xs border border-ds-outline-variant text-ds-on-surface-variant hover:border-ds-primary hover:text-ds-on-surface hover:bg-ds-surface-high transition-all duration-150"
                    >
                      <HugeiconsIcon icon={link.icon} className="w-3.5 h-3.5" size={14} />
                      <span class="hidden sm:inline">{link.label}</span>
                    </a>
                  ))}
                  {sponsorLinks.map((link) => (
                    <a
                      href={link.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      title={link.label}
                      class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold bg-ds-primary text-ds-on-primary hover:opacity-90 transition-all duration-150"
                    >
                      <HugeiconsIcon icon={link.icon} className="w-3.5 h-3.5" size={14} />
                      {link.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </MagicCard>
        );
      })}
    </div>
  </div>
)}

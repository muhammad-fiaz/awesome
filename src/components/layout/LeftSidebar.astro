---
import { Icon } from 'astro-icon/components';
import { NAV_LINKS, DISCOVER_LINKS, COMMUNITY_LINKS, BASE_PATH, OWNER } from '@/config/site';
import { SidebarInteractive } from '@/components/layout/SidebarInteractive';

interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;

function isActive(href: string): boolean {
  if (href === `${BASE_PATH}/`) return currentPath === href;
  return currentPath.startsWith(href);
}

const ICON_MAP: Record<string, string> = {
  home: 'mdi:home-outline',
  article: 'mdi:file-document-outline',
  category: 'mdi:shape-outline',
  sell: 'mdi:tag-outline',
  person: 'mdi:account-outline',
  star: 'mdi:star-outline',
  schedule: 'mdi:clock-outline',
  rss_feed: 'mdi:rss',
  favorite: 'mdi:heart-outline',
  help: 'mdi:help-circle-outline',
  policy: 'mdi:shield-check-outline',
};
---

<aside
  id="left-sidebar"
  class="hidden md:flex flex-col fixed left-0 top-16 bottom-0 w-(--sidebar-width) bg-ds-surface-low border-r border-ds-outline-variant overflow-hidden z-40 transition-[width] duration-200 ease-in-out"
>
  <nav class="flex flex-col gap-0.5 p-3 h-full overflow-y-auto">
    <div class="hidden md:flex items-center pb-2 border-b border-ds-outline-variant mb-2 justify-between px-2" id="sidebar-header">
      <span class="text-[10px] font-bold uppercase tracking-wider text-ds-text-muted sidebar-label">Menu</span>
      <SidebarInteractive client:load desktop={true} />
    </div>

    <div class="px-2 py-1 new-post-wrapper">
      <a
        href={`${BASE_PATH}/guide/`}
        class="new-post-btn flex items-center justify-center gap-2 w-full px-3 py-2 rounded-lg text-sm font-bold bg-ds-primary text-ds-on-primary hover:opacity-90 transition-opacity"
      >
        <Icon name="mdi:plus" class="w-4 h-4 shrink-0" />
        <span class="sidebar-label">New Post</span>
      </a>
    </div>

    <div class="space-y-0.5">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={[
            'flex items-center rounded-lg text-sm font-medium transition-all duration-150 gap-3 px-3 py-2',
            isActive(link.href)
              ? 'bg-ds-primary-container text-ds-on-primary-container'
              : 'text-ds-on-surface-variant hover:text-ds-on-surface hover:bg-ds-surface-high',
          ]}
          title={link.label}
        >
          <Icon name={ICON_MAP[link.icon] ?? `mdi:${link.icon}`} class="w-5 h-5 shrink-0" />
          <span class="text-xs font-bold tracking-wide uppercase truncate sidebar-label">{link.label}</span>
        </a>
      ))}
    </div>

    <div class="border-t border-ds-outline-variant my-2"></div>
    <div class="px-3 pb-1 sidebar-label-wrapper">
      <span class="text-[10px] font-bold tracking-widest uppercase text-ds-text-muted">Discover</span>
    </div>
    <div class="space-y-0.5">
      {DISCOVER_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={[
            'flex items-center rounded-lg text-sm font-medium transition-all duration-150 gap-3 px-3 py-2',
            isActive(link.href)
              ? 'bg-ds-primary-container text-ds-on-primary-container'
              : 'text-ds-on-surface-variant hover:text-ds-on-surface hover:bg-ds-surface-high',
          ]}
          title={link.label}
        >
          <Icon name={ICON_MAP[link.icon] ?? `mdi:${link.icon}`} class="w-5 h-5 shrink-0" />
          <span class="text-xs font-bold tracking-wide uppercase truncate sidebar-label">{link.label}</span>
        </a>
      ))}
    </div>

    <div class="border-t border-ds-outline-variant my-2"></div>
    <div class="px-3 pb-1 sidebar-label-wrapper">
      <span class="text-[10px] font-bold tracking-widest uppercase text-ds-text-muted">Community</span>
    </div>
    <div class="space-y-0.5">
      {COMMUNITY_LINKS.map((link) => (
        <a
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
          class:list={[
            'flex items-center rounded-lg text-sm font-medium transition-all duration-150 gap-3 px-3 py-2',
            isActive(link.href)
              ? 'bg-ds-primary-container text-ds-on-primary-container'
              : 'text-ds-on-surface-variant hover:text-ds-on-surface hover:bg-ds-surface-high',
          ]}
          title={link.label}
        >
          <Icon name={ICON_MAP[link.icon] ?? `mdi:${link.icon}`} class="w-5 h-5 shrink-0" />
          <span class="text-xs font-bold tracking-wide uppercase truncate sidebar-label">{link.label}</span>
          {link.external && <Icon name="mdi:open-in-new" class="w-3 h-3 ml-auto opacity-40 sidebar-label" />}
        </a>
      ))}
    </div>
  </nav>
</aside>

<SidebarInteractive client:load mobile={true} currentPath={currentPath} />

<style>
  :global(.sidebar-collapsed) #left-sidebar .sidebar-label {
    display: none;
  }
  :global(.sidebar-collapsed) #left-sidebar a:not(.new-post-btn) {
    justify-content: center;
    padding: 0.625rem;
    gap: 0;
  }
  :global(.sidebar-collapsed) #left-sidebar .sidebar-label-wrapper {
    display: none;
  }
  :global(.sidebar-collapsed) #left-sidebar #sidebar-header {
    justify-content: center;
    padding-left: 0;
    padding-right: 0;
  }
  :global(.sidebar-collapsed) #left-sidebar .new-post-wrapper {
    display: flex;
    justify-content: center;
  }
  :global(.sidebar-collapsed) #left-sidebar .new-post-btn {
    width: auto;
    padding: 0.625rem;
    border-radius: 0.5rem;
  }
</style>
